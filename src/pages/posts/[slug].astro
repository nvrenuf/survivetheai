---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { readingTime } from '../../utils/readingTime';
import { isPublicPost } from '../../utils/postSections';
import PlaybookOffer from '../../components/PlaybookOffer.astro';
import { assertLivePostStandards } from '../../utils/livePostStandards';

export async function getStaticPaths() {
  const posts = assertLivePostStandards((await getCollection('posts')).filter(isPublicPost));
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await post.render();
const { minutes } = readingTime(post.body ?? '');
const shareUrl = post.data.canonicalUrl || new URL(`/posts/${post.slug}/`, Astro.site ?? 'https://survivetheai.com').toString();
const affiliate = post.data.affiliate_offer;
---
<PostLayout
  post={post}
  headings={headings}
  readingTime={minutes}
  shareUrl={shareUrl}
  allPosts={allPosts}
>
  {affiliate && (
    <PlaybookOffer
      slot="inline-cta"
      eyebrow="Reader resource"
      title={affiliate.label}
      description={affiliate.description ?? 'Free reader resource with practical next steps.'}
      href="/playbook"
      ctaLabel="Get the free playbook"
      secondaryHref="/start-here"
      secondaryLabel="Open Start Here"
      disclaimer="Free resource. Placed here to extend the article, not interrupt it."
      testId="article-playbook-offer"
    />
  )}
  <Content />
</PostLayout>
