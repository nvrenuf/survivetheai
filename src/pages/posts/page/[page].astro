---
import Layout from '../../../layouts/BaseLayout.astro';
import ArchiveBrowsePanel from '../../../components/ArchiveBrowsePanel.astro';
import BlogList from '../../../components/BlogList.astro';
import { getCollection } from 'astro:content';
import { isArchiveVisiblePost, paginatePosts, sortPosts, SURVIVAL_LIBRARY_PAGE_SIZE } from '../../../utils/postSections';
import type { PostEntry } from '../../../content/config';
import { getHubKeysForPost } from '../../../utils/postLinking';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const sortedPosts = sortPosts(posts).filter(isArchiveVisiblePost);
  const { pages, totalPages } = paginatePosts(sortedPosts, SURVIVAL_LIBRARY_PAGE_SIZE);
  const hubCounts: Record<string, number> = {};

  for (const post of sortedPosts) {
    for (const hubKey of getHubKeysForPost(post)) {
      hubCounts[hubKey] = (hubCounts[hubKey] ?? 0) + 1;
    }
  }

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const pageNumber = index + 2;
    const pagePosts = pages[pageNumber - 1] ?? [];

    return {
      params: { page: pageNumber.toString() },
      props: { pageNumber, totalPages, pagePosts, totalPosts: sortedPosts.length, hubCounts },
      route: `/posts/page/${pageNumber}/`,
    };
  });
}

const { pageNumber, totalPages, pagePosts, totalPosts, hubCounts } = Astro.props as {
  pageNumber: number;
  totalPages: number;
  pagePosts: PostEntry[];
  totalPosts: number;
  hubCounts: Record<string, number>;
};

const pageTitle = `Survival Library - Page ${pageNumber}`;
---

<Layout title={`${pageTitle} · Survive the AI`} description="SurviveTheAI post archive with pagination.">
  <main class="bg-white py-14 text-neutral-900 sm:py-16">
    <div class="mx-auto max-w-screen-xl space-y-8 px-4 sm:px-6 lg:px-8">
      <ArchiveBrowsePanel
        pageTitle={pageTitle}
        pageDescription="Keep moving through the reporting archive in sequence, or break out into a Survival Area when you want one focused pressure map."
        currentPage={pageNumber}
        totalPages={totalPages}
        totalPosts={totalPosts}
        hubCounts={hubCounts}
      />
      <BlogList posts={pagePosts} currentPage={pageNumber} totalPages={totalPages} basePath="/posts" />
    </div>
  </main>
</Layout>
