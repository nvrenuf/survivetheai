---
import Layout from '../layouts/BaseLayout.astro';
---

<Layout title="Contact - SurviveTheAI" description="Reach the SurviveTheAI editor with questions, pitches, or corrections.">
  <main class="bg-white py-14 text-neutral-900 sm:py-16">
    <div class="mx-auto max-w-screen-xl space-y-8 px-4 sm:px-6 lg:px-8">
      <header class="space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Contact</p>
        <h1 class="text-3xl font-extrabold text-neutral-900 sm:text-4xl">Contact the editor</h1>
        <p class="max-w-3xl text-lg text-neutral-700 sm:text-xl">
          If you spotted an error, have a reporting note, or want to reach the publication, send an email. This page is an email path, not a
          live contact form.
        </p>
      </header>

      <div class="grid gap-6 lg:grid-cols-2">
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-black text-neutral-900">General inquiries</h2>
          <p class="mt-3 text-neutral-700">
            Email <a href="mailto:editor@survivetheai.com" class="underline hover:text-neutral-900">editor@survivetheai.com</a> for reader
            questions, partnerships, and editorial notes.
          </p>
        </div>
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-black text-neutral-900">Corrections</h2>
          <p class="mt-3 text-neutral-700">
            If you see an error, include the article link, the issue, and any source material. Email
            <a href="mailto:editor@survivetheai.com" class="underline hover:text-neutral-900"> editor@survivetheai.com</a>.
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
