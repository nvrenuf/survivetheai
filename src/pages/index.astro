---
import { getCollection } from 'astro:content';
import CredibilityPanel from '../components/CredibilityPanel.astro';
import PlaybookOffer from '../components/PlaybookOffer.astro';
import PostCard from '../components/PostCard.astro';
import PressureRoom from '../components/homepage/PressureRoom.astro';
import SubscribeInline from '../components/SubscribeInline';
import { buildHomepagePlacement } from '../data/homepage';
import { buildHomepageBoard } from '../data/homepageBoard';
import Layout from '../layouts/BaseLayout.astro';
import { formatDate } from '../utils/format';

const posts = await getCollection('posts');
const { editorPicks, remaining } = buildHomepagePlacement(posts);
const board = buildHomepageBoard(posts);
const heroSignals = board.liveModules.slice(0, 3);
const topThreats = board.threatCards.slice(0, 3);
const supportingPosts = (editorPicks.length > 0 ? editorPicks : remaining).slice(0, 3);
---

<Layout title="Survive the AI - Prepare, adapt, and stay ahead">
  <main class="bg-[radial-gradient(circle_at_top,rgba(148,163,184,0.08),transparent_24%),linear-gradient(180deg,#fbfbfa_0%,#f4f4f2_42%,#ecece8_100%)] py-8 text-neutral-900 sm:py-10 lg:py-12">
    <div class="mx-auto max-w-screen-xl space-y-8 px-4 sm:px-6 lg:px-8 lg:space-y-10">
      <section class="rounded-[2rem] border border-stone-200 bg-[linear-gradient(180deg,rgba(255,255,255,0.98),rgba(248,246,242,0.98))] px-5 py-6 shadow-[0_24px_70px_-50px_rgba(28,25,23,0.22)] sm:px-6 sm:py-7 lg:px-8" data-testid="homepage-hero">
        <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_340px] xl:items-start xl:gap-8">
          <div class="space-y-5">
            <div class="flex flex-wrap items-center gap-3">
              <span class="inline-flex items-center gap-2 rounded-full border border-orange-200 bg-orange-50 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.24em] text-orange-700">
                <span class="h-1.5 w-1.5 rounded-full bg-orange-500" aria-hidden="true"></span>
                LIVE AI PRESSURE BOARD
              </span>
              <span class="text-xs font-medium uppercase tracking-[0.22em] text-stone-500">Updated through {board.anchorDateLabel}</span>
            </div>

            <div class="max-w-4xl space-y-3.5">
              <h1 class="max-w-3xl text-4xl font-black leading-[0.96] tracking-[-0.04em] text-stone-950 sm:text-[3.3rem]">
                The AI flood is here. Learn to swim.
              </h1>
              <p class="max-w-[42rem] text-base leading-8 text-stone-700 sm:text-[1.02rem]">
                SurviveTheAI is a live dashboard for everyday AI risk across work, school, trust, and attention. Check the board first, then use the reporting when you need the mechanism behind the signal.
              </p>
            </div>

            <div class="flex flex-wrap gap-3">
              <a
                href="#pressure-room"
                class="inline-flex items-center justify-center rounded-full bg-stone-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-stone-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-500/40"
                data-testid="hero-pressure-room-link"
              >
                Open the board
              </a>
              <a
                href="/how-we-research"
                class="inline-flex items-center justify-center rounded-full border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition hover:border-stone-400 hover:bg-stone-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-500/30"
              >
                Why trust this
              </a>
            </div>

            <div class="grid gap-3 md:grid-cols-3">
              {heroSignals.map((signal) => (
                <article class="rounded-[1.4rem] border border-stone-200 bg-white p-4 shadow-[0_12px_28px_-24px_rgba(28,25,23,0.35)] sm:p-5">
                  <p class="text-[10px] font-semibold uppercase tracking-[0.28em] text-stone-500">{signal.title}</p>
                  <p class="mt-3 text-[1.65rem] font-black tracking-[-0.03em] text-stone-950">{signal.value}</p>
                  <p class="mt-2.5 text-sm leading-7 text-stone-600">{signal.summary}</p>
                </article>
              ))}
            </div>
          </div>

          <aside class="rounded-[1.7rem] border border-stone-200 bg-[linear-gradient(180deg,rgba(249,248,245,0.98),rgba(244,241,236,0.98))] p-4 shadow-[0_18px_40px_-34px_rgba(28,25,23,0.28)] sm:p-5" data-testid="most-watched-panel">
            <div class="border-b border-stone-200 pb-3.5">
              <p class="text-[10px] font-semibold uppercase tracking-[0.34em] text-stone-500">Top pressure zones</p>
              <p class="mt-1.5 text-sm leading-6 text-stone-600">The fear areas carrying the strongest editorial pressure right now.</p>
            </div>

            <div class="mt-5 space-y-3.5">
              {topThreats.map((threat) => (
                <a
                  href={`${threat.hub.slug}/`}
                  class="block rounded-[1.25rem] border border-stone-200 bg-white p-4 transition hover:border-stone-300 hover:bg-stone-50 sm:p-[1.125rem]"
                >
                  <div class="flex items-center justify-between gap-3">
                    <div class="flex items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.26em] text-stone-500">
                      <span class="h-2 w-2 rounded-full" style={`background:${threat.hub.color}`} aria-hidden="true"></span>
                      <span>{threat.hub.shortName}</span>
                    </div>
                    <span class="rounded-full border border-stone-200 bg-stone-50 px-2.5 py-1 text-[11px] font-semibold tracking-[0.02em] text-stone-900">
                      {threat.score}
                    </span>
                  </div>
                  <p class="mt-4 text-sm font-semibold leading-6 text-stone-900">{threat.stance}</p>
                </a>
              ))}
            </div>
          </aside>
        </div>
      </section>

      <PressureRoom board={board} />

      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-start">
        {supportingPosts.length > 0 && (
          <section
            class="rounded-[2rem] border border-stone-200 bg-[linear-gradient(180deg,rgba(255,255,255,0.98),rgba(247,244,239,0.96))] px-5 py-6 shadow-[0_24px_70px_-50px_rgba(28,25,23,0.18)] sm:px-6 sm:py-7 lg:px-8"
            data-testid="supporting-analysis-section"
          >
            <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
              <div class="max-w-3xl space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.32em] text-stone-500">Suggested First Reads</p>
                <h2 class="text-2xl font-black text-stone-950 sm:text-3xl">Read the reporting behind the dashboard</h2>
                <p class="max-w-[42rem] text-[15px] leading-7 text-stone-600 sm:text-base">
                  Keep the homepage focused on the board. Use a small number of strong posts when you want the deeper explanation behind the signal.
                </p>
              </div>
              <a
                href="/posts"
                class="inline-flex items-center justify-center rounded-full border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-stone-900 transition hover:border-stone-400 hover:bg-stone-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-400/30"
              >
                Browse all reporting
              </a>
            </div>

            <div class="grid gap-4 pt-2 lg:grid-cols-3">
              {supportingPosts.map((post) => (
                <PostCard post={post} />
              ))}
            </div>
          </section>
        )}

        <div class="space-y-5">
          <CredibilityPanel eyebrow="Trust" title="Clear standards and visible ownership" />

          <SubscribeInline
            client:load
            location="home"
            heading="Get the weekly briefing"
            helperText="One concise weekly email with the newest signal, what it means, and where to act next."
            privacyText="Free. No spam. Unsubscribe anytime."
          />
        </div>
      </div>

      <div class="rounded-[1.8rem] border border-stone-200 bg-white p-[1px] shadow-[0_16px_42px_-32px_rgba(28,25,23,0.24)]">
        <PlaybookOffer
          eyebrow="Reader offer"
          title="Get the free Survival Playbook"
          description="If you want one clear next-step resource beyond the dashboard, use the playbook."
          href="/playbook"
          ctaLabel="Get the free playbook"
          secondaryHref="/start-here"
          secondaryLabel="Open Start Here"
          disclaimer="Free reader resource. No aggressive funnel."
          testId="homepage-playbook-offer"
          primaryAnalyticsEvent="playbook_cta_click"
          primaryAnalyticsLocation="homepage-playbook-offer"
          secondaryAnalyticsEvent="start_here_entry_click"
          secondaryAnalyticsLocation="homepage-playbook-offer"
        />
      </div>
    </div>
  </main>
</Layout>
