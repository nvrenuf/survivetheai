---
import Layout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SubscribeInline from '../components/SubscribeInline';
import CredibilityPanel from '../components/CredibilityPanel.astro';
import { getCollection } from 'astro:content';
import { buildHomepagePlacement } from '../data/homepage';
import { SURVIVAL_HUBS } from '../data/hubs';

const posts = await getCollection('posts');
const { featured, editorPicks } = buildHomepagePlacement(posts);
const survivalAreas = [...SURVIVAL_HUBS].sort((a, b) => a.order - b.order);
---

<Layout title="Start Here - Survive the AI" description="A guided first path through SurviveTheAI for new readers.">
  <main class="bg-white py-14 text-neutral-900 sm:py-16">
    <div class="mx-auto max-w-screen-xl space-y-10 px-4 sm:px-6 lg:px-8" data-testid="start-here-page">
      <header class="space-y-4">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Start Here</p>
        <h1 class="text-3xl font-extrabold text-neutral-900 sm:text-4xl">A guided first path through SurviveTheAI</h1>
        <p class="max-w-4xl text-lg text-neutral-700 sm:text-xl">
          New here: start with the pressure map, then learn how STA evaluates claims, and then move into the fear area that matters most to
          your work, family, or attention.
        </p>
      </header>

      <section class="grid gap-6 lg:grid-cols-3" data-testid="start-here-steps">
        <article class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm" data-testid="start-here-step">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Step 1</p>
          <h2 class="mt-2 text-2xl font-black text-neutral-900">See the pressure clearly</h2>
          <p class="mt-3 text-neutral-700">
            Start with the most urgent story so you understand what STA means by AI pressure, household stakes, and adaptation cost.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            {featured && (
              <a
                href={`/posts/${featured.slug}/`}
                class="inline-flex items-center justify-center rounded-full bg-neutral-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-neutral-800"
                data-testid="start-here-featured-link"
              >
                Read the urgent story
              </a>
            )}
            <a
              href="/posts"
              class="inline-flex items-center justify-center rounded-full border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-900 transition hover:border-neutral-500 hover:text-neutral-950"
            >
              Browse the Survival Library
            </a>
          </div>
        </article>

        <article class="rounded-3xl border border-neutral-200 bg-neutral-50 p-6 shadow-sm" data-testid="start-here-step">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Step 2</p>
          <h2 class="mt-2 text-2xl font-black text-neutral-900">Check how STA works</h2>
          <p class="mt-3 text-neutral-700">
            Trust the framework only if you can inspect it. Review who publishes the site, how claims are handled, and how Impact Score should
            be read.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href="/about" class="inline-flex items-center justify-center rounded-full border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-900 transition hover:border-neutral-500 hover:text-neutral-950">
              About STA
            </a>
            <a href="/how-we-research" class="inline-flex items-center justify-center rounded-full border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-900 transition hover:border-neutral-500 hover:text-neutral-950">
              How we research
            </a>
            <a href="/impact-score-methodology" class="inline-flex items-center justify-center rounded-full border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-900 transition hover:border-neutral-500 hover:text-neutral-950">
              Impact Score methodology
            </a>
          </div>
        </article>

        <article class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm" data-testid="start-here-step">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Step 3</p>
          <h2 class="mt-2 text-2xl font-black text-neutral-900">Pick your fear area</h2>
          <p class="mt-3 text-neutral-700">
            Once you understand the framework, go narrower. Open the survival area that matches the pressure building around your life first.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            {survivalAreas.map((hub) => (
              <a
                href={`${hub.slug}/`}
                class="inline-flex items-center justify-center rounded-full border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-900 transition hover:border-neutral-500 hover:text-neutral-950"
              >
                {hub.shortName}
              </a>
            ))}
          </div>
        </article>
      </section>

      {editorPicks.length > 0 && (
        <section class="space-y-5" data-testid="start-here-editor-picks">
          <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Suggested first reads</p>
            <h2 class="text-2xl font-black text-neutral-900 sm:text-3xl">If you want a quick guided path, start with these three</h2>
            <p class="max-w-3xl text-neutral-700">
              These pieces cover work, family, and relationships without forcing you to scan the whole archive first.
            </p>
          </div>
          <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            {editorPicks.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        </section>
      )}

      <CredibilityPanel
        eyebrow="Trust check"
        title="Inspect the site before you invest your attention"
        summary="Use the pages above to see who publishes STA, how claims are handled, and how editorial scores are meant to be interpreted before you go deeper."
      />

      <section>
        <SubscribeInline
          client:load
          location="start-here"
          heading="Get the weekly STA briefing"
          helperText="One concise weekly email with the newest signal, what it means, and where to act next."
          privacyText="Free. No spam. Unsubscribe anytime."
        />
      </section>
    </div>
  </main>
</Layout>
