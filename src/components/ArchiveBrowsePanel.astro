---
import { SURVIVAL_HUBS } from '../data/hubs';

const {
  pageTitle = 'Survival Library',
  pageDescription,
  currentPage = 1,
  totalPages = 1,
  totalPosts = 0,
  hubCounts = {},
} = Astro.props as {
  pageTitle?: string;
  pageDescription?: string;
  currentPage?: number;
  totalPages?: number;
  totalPosts?: number;
  hubCounts?: Record<string, number>;
};

const sortedHubs = [...SURVIVAL_HUBS].sort((a, b) => a.order - b.order);
---

<section class="space-y-6" data-testid="archive-browse-panel">
  <div class="grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(280px,0.85fr)]">
    <div class="space-y-3">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Archive</p>
      <h1 class="text-3xl font-extrabold text-neutral-900 sm:text-4xl">{pageTitle}</h1>
      <p class="max-w-3xl text-neutral-600">
        {pageDescription}
      </p>
    </div>
    <div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">How to browse</p>
      <ul class="mt-4 space-y-3 text-sm leading-relaxed text-neutral-700">
        <li>Use the newest page to scan fresh pressure points first.</li>
        <li>Jump into a Survival Area when you want one problem space instead of the full stream.</li>
        <li>Use page numbers when you want to move deeper through the reporting archive without losing sequence.</li>
      </ul>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.9fr)]">
    <div
      id="archive-survival-areas"
      class="rounded-3xl border border-neutral-200 bg-white p-5 shadow-sm sm:p-6"
      data-testid="archive-survival-areas"
    >
      <div class="space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Browse by survival area</p>
        <h2 class="text-2xl font-black text-neutral-900">Choose the pressure map you want</h2>
      </div>
      <div class="mt-5 grid gap-3 sm:grid-cols-2">
        {sortedHubs.map((hub) => (
          <a
            href={`${hub.slug}/`}
            class="group flex items-start justify-between gap-3 rounded-2xl border border-neutral-200 px-4 py-4 transition hover:border-neutral-300 hover:bg-neutral-50"
            data-testid="archive-hub-link"
          >
            <div class="space-y-1">
              <p class="text-sm font-semibold text-neutral-900 transition group-hover:text-neutral-700">{hub.shortName}</p>
              <p class="text-sm leading-relaxed text-neutral-600">{hub.tagline}</p>
            </div>
            <span class="shrink-0 rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-neutral-700">
              {hubCounts[hub.key] ?? 0}
            </span>
          </a>
        ))}
      </div>
    </div>

    <div class="rounded-3xl border border-neutral-200 bg-white p-5 shadow-sm sm:p-6" data-testid="archive-page-context">
      <div class="space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Library status</p>
        <h2 class="text-2xl font-black text-neutral-900">Keep your place in the archive</h2>
      </div>
      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl bg-neutral-50 px-4 py-4">
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-neutral-500">Total posts</p>
          <p class="mt-2 text-2xl font-black text-neutral-900">{totalPosts}</p>
        </div>
        <div class="rounded-2xl bg-neutral-50 px-4 py-4">
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-neutral-500">Current page</p>
          <p class="mt-2 text-2xl font-black text-neutral-900">{currentPage}</p>
        </div>
        <div class="rounded-2xl bg-neutral-50 px-4 py-4">
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-neutral-500">Total pages</p>
          <p class="mt-2 text-2xl font-black text-neutral-900">{totalPages}</p>
        </div>
      </div>
    </div>
  </div>
</section>
