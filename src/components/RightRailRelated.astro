---
import type { PostEntry } from '../content/config';
import PostCardMeta from './PostCardMeta.astro';

const { related, heading = 'Related reading' } = Astro.props as {
  related: PostEntry[];
  heading?: string;
};
---
<section class="space-y-4">
  <h2 class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-600">{heading}</h2>
  <ul class="space-y-4" data-testid="related-rail">
    {related.map((entry) => {
      const heroImage = entry.data.heroImage;
      const hasHero = typeof heroImage === 'string' && heroImage.trim().length > 0;

      return (
        <li>
          <a
            href={`/posts/${entry.slug}/`}
            class="group flex items-start gap-4 rounded-2xl border border-neutral-200 bg-white p-3 shadow-sm transition hover:border-neutral-300 hover:bg-neutral-50"
            data-testid="compact-post-card"
          >
            <div class="relative h-20 w-20 flex-none overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-50">
              {hasHero && (
                <img
                  src={heroImage}
                  alt={entry.data.title}
                  loading="lazy"
                  decoding="async"
                  width="80"
                  height="80"
                  class="h-full w-full object-cover"
                  onerror="this.style.display='none'; const placeholder = this.nextElementSibling; if (placeholder) placeholder.classList.remove('hidden');"
                />
              )}
              <div class={`absolute inset-0 flex items-center justify-center text-[10px] font-medium text-neutral-400 ${hasHero ? 'hidden' : ''}`}>
                No image
              </div>
            </div>
            <div class="flex min-w-0 flex-1 flex-col gap-3 py-1">
              <div class="space-y-2">
                <PostCardMeta post={entry} compact={true} />
                <p
                  class="text-sm font-semibold leading-snug text-neutral-900 transition group-hover:text-neutral-700"
                  style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"
                >
                  {entry.data.title}
                </p>
              </div>
              <div class="mt-auto border-t border-neutral-100 pt-3">
                <PostCardMeta post={entry} compact={true} showImpact={true} />
              </div>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</section>
