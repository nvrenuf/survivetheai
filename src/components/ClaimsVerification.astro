---
import type { ClaimsVerificationEntry } from '../data/claimsVerification';

const { entry } = Astro.props as { entry: ClaimsVerificationEntry };
const note = entry.note ?? 'This section is updated when sourcing improves, evidence changes, or a claim needs to be narrowed.';
---

<section
  class="space-y-5 rounded-3xl border border-neutral-200 bg-neutral-50 px-6 py-6 shadow-sm sm:px-7"
  data-testid="article-claims-verification"
>
  <div class="space-y-2">
    <p class="text-xs font-semibold uppercase tracking-[0.3em] text-neutral-500">Claims & Verification</p>
    <h2 class="text-2xl font-black text-neutral-900 sm:text-3xl">What we can defend, what remains uncertain</h2>
  </div>
  <div class="grid gap-5 lg:grid-cols-2">
    <div class="space-y-3">
      <h3 class="text-sm font-semibold uppercase tracking-[0.24em] text-neutral-700">Well-supported</h3>
      <ul class="space-y-3 text-sm leading-relaxed text-neutral-800 sm:text-base">
        {entry.supported.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="space-y-3">
      <h3 class="text-sm font-semibold uppercase tracking-[0.24em] text-neutral-700">Still uncertain</h3>
      <ul class="space-y-3 text-sm leading-relaxed text-neutral-800 sm:text-base">
        {entry.uncertain.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
  <p class="text-sm leading-relaxed text-neutral-600">{note}</p>
</section>
