# Newsletter / playbook signup capture
# PUBLIC_ENABLE_SUBSCRIBE_API gates the capture endpoints and client submit flow.
PUBLIC_ENABLE_SUBSCRIBE_API=false
SITE_URL=https://survivetheai.com
SUPABASE_URL=
# Prefer the service role key for server-side subscribe/confirm/unsubscribe handlers.
SUPABASE_SERVICE_ROLE_KEY=
# Optional fallback only if service role is not available.
SUPABASE_ANON_KEY=
RESEND_API_KEY=
RESEND_FROM=

# Analytics (optional)
# Provide a GA4 measurement ID to enable basic page + event tracking.
PUBLIC_GA_MEASUREMENT_ID=
# Set to "true" to log analytics events to the console when GA is not configured.
PUBLIC_ANALYTICS_DEBUG=false
